{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://botctl.dev/schemas/runtime-probe.schema.json",
  "title": "Bot local runtime probe v0",
  "type": "object",
  "required": ["apiVersion", "kind", "generated_at", "read_only", "scope", "summary", "checks", "safety"],
  "properties": {
    "apiVersion": {"const": "botctl.dev/v0"},
    "kind": {"const": "BotLocalRuntimeProbe"},
    "generated_at": {"type": "string"},
    "read_only": {"const": true},
    "scope": {"const": "local_metadata_only"},
    "summary": {
      "type": "object",
      "required": ["status", "failures", "warnings", "checks"],
      "properties": {
        "status": {"enum": ["passed", "degraded", "failed"]},
        "failures": {"type": "integer", "minimum": 0},
        "warnings": {"type": "integer", "minimum": 0},
        "checks": {"type": "integer", "minimum": 1}
      }
    },
    "checks": {"type": "array", "minItems": 1, "items": {"type": "object"}},
    "safety": {
      "type": "object",
      "required": ["reads_secrets", "reads_file_contents", "reads_databases", "contacts_network", "sends_runtime_signals", "restarts_runtime", "writes_runtime"],
      "additionalProperties": {"const": false}
    }
  }
}
