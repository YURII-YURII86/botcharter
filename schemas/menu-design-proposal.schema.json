{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://botctl.dev/schemas/menu-design-proposal.schema.json",
  "title": "Bot Menu Design Proposal v0",
  "type": "object",
  "required": ["apiVersion", "kind", "read_only", "roles", "command_contract", "menus", "callback_contract", "implementation_policy"],
  "properties": {
    "apiVersion": {"const": "botctl.dev/v0"},
    "kind": {"const": "BotMenuDesignProposal"},
    "generated_at": {"type": "string"},
    "project_path": {"type": "string"},
    "read_only": {"const": true},
    "source_kind": {"type": "string"},
    "critique_summary": {"type": "object"},
    "brief_validation": {"type": "object"},
    "draft_notice": {"type": "string"},
    "roles": {"type": "array", "items": {"$ref": "#/$defs/role"}},
    "command_contract": {"type": "array", "items": {"$ref": "#/$defs/command"}},
    "menus": {"type": "array", "items": {"$ref": "#/$defs/menu"}},
    "callback_contract": {"type": "array", "items": {"$ref": "#/$defs/callback"}},
    "global_navigation_requirements": {"type": "object"},
    "quality_gates": {"type": "array", "items": {"type": "object"}},
    "design_debt": {"type": "array", "items": {"type": "object"}},
    "implementation_policy": {"$ref": "#/$defs/policy"}
  },
  "$defs": {
    "role": {"type": "object", "required": ["id", "title"], "properties": {"id": {"type": "string"}, "title": {"type": "string"}, "description": {"type": "string"}, "requires_manual_confirmation": {"type": "boolean"}}, "additionalProperties": true},
    "command": {"type": "object", "required": ["command", "visible_for"], "properties": {"command": {"type": "string", "pattern": "^/[a-z][a-z0-9_]{1,31}$"}, "visible_for": {"type": "array", "items": {"type": "string"}}, "description": {"type": "string"}, "handler_hint": {"type": ["string", "null"]}}, "additionalProperties": true},
    "menu": {"type": "object", "required": ["id", "visible_for", "buttons"], "properties": {"id": {"type": "string"}, "title": {"type": "string"}, "visible_for": {"type": "array", "items": {"type": "string"}}, "buttons": {"type": "array", "items": {"type": "object"}}, "navigation_requirements": {"type": "object"}}, "additionalProperties": true},
    "callback": {"type": "object", "required": ["namespace", "patterns", "allowed_roles"], "properties": {"namespace": {"type": "string"}, "actions_hint": {"type": "array", "items": {"type": "string"}}, "patterns": {"type": "array", "items": {"type": "string"}}, "allowed_roles": {"type": "array", "items": {"type": "string"}}, "handler_hints": {"type": "array", "items": {"type": "string"}}, "requires_permission_guard": {"type": "boolean"}, "requires_confirmation": {"type": "boolean"}, "idempotency_required": {"type": "boolean"}}, "additionalProperties": true},
    "policy": {"type": "object", "required": ["mode"], "properties": {"mode": {"const": "proposal_only"}, "must_confirm_roles_against_access_control": {"type": "boolean"}, "must_add_tests_before_runtime_apply": {"type": "boolean"}, "forbidden_without_change_plan": {"type": "array", "items": {"type": "string"}}}, "additionalProperties": true}
  },
  "additionalProperties": true
}
