{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://botctl.dev/schemas/menu-implementation-plan.schema.json",
  "title": "Bot Menu Implementation Plan v0",
  "type": "object",
  "required": ["apiVersion", "kind", "read_only", "summary", "suggested_files", "handler_skeleton", "phases", "test_matrix", "blocked_actions"],
  "properties": {
    "apiVersion": {"const": "botctl.dev/v0"},
    "kind": {"const": "BotMenuImplementationPlan"},
    "generated_at": {"type": "string"},
    "project_path": {"type": "string"},
    "read_only": {"const": true},
    "source_kind": {"type": "string"},
    "summary": {"type": "object", "required": ["mode"], "properties": {"mode": {"const": "plan_only"}}, "additionalProperties": true},
    "suggested_files": {"type": "array", "items": {"type": "object", "required": ["path", "purpose"], "properties": {"path": {"type": "string"}, "purpose": {"type": "string"}}, "additionalProperties": true}},
    "handler_skeleton": {"type": "array", "items": {"type": "object", "required": ["name", "purpose"], "properties": {"name": {"type": "string"}, "purpose": {"type": "string"}}, "additionalProperties": true}},
    "phases": {"type": "array", "minItems": 1, "items": {"type": "object", "required": ["id", "title", "steps", "verification"], "properties": {"id": {"type": "string"}, "title": {"type": "string"}, "steps": {"type": "array", "items": {"type": "string"}}, "verification": {"type": "array", "items": {"type": "string"}}}, "additionalProperties": true}},
    "test_matrix": {"type": "array", "items": {"type": "object", "required": ["id", "title"], "properties": {"id": {"type": "string"}, "title": {"type": "string"}, "covers": {"type": "array"}}, "additionalProperties": true}},
    "dangerous_callbacks": {"type": "array", "items": {"type": "object"}},
    "design_debt_to_resolve": {"type": "array", "items": {"type": "object"}},
    "rollback_strategy": {"type": "array", "items": {"type": "string"}},
    "blocked_actions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "next_agent_prompt": {"type": "string"}
  },
  "additionalProperties": true
}
