{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://botctl.dev/schemas/impact-graph.schema.json",
  "title":"Bot Impact Graph v0",
  "type":"object",
  "required":["apiVersion","kind","knowledge_status","nodes","edges"],
  "properties":{
    "apiVersion":{"const":"botctl.dev/v0"},
    "kind":{"const":"BotImpactGraph"},
    "knowledge_status":{"enum":["draft","reviewed","confirmed","deprecated","missing"]},
    "nodes":{"type":"array","items":{"type":"object","required":["id","kind"],"additionalProperties":true}},
    "edges":{"type":"array","items":{"type":"object","required":["source","target","kind"],"additionalProperties":true}},
    "graph_status":{"type":"string"}
  },
  "additionalProperties":true
}
