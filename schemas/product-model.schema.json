{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://botctl.dev/schemas/product-model.schema.json",
  "title":"Bot Product Model v0",
  "type":"object",
  "required":["apiVersion","kind","knowledge_status","requires_review","production_design_allowed"],
  "properties":{
    "apiVersion":{"const":"botctl.dev/v0"},
    "kind":{"const":"BotProductModel"},
    "knowledge_status":{"enum":["draft","reviewed","confirmed","deprecated","missing"]},
    "requires_review":{"type":"boolean"},
    "production_design_allowed":{"const":false},
    "open_questions":{"type":"array","items":{"type":"string"}},
    "assumptions":{"type":"array"}
  },
  "additionalProperties":true
}
