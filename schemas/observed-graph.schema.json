{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://botctl.dev/schemas/observed-graph.schema.json",
  "title": "Observed Graph v0",
  "type": "object",
  "required": ["apiVersion", "kind", "generated_at", "source", "runtime_probe", "nodes", "edges", "findings"],
  "properties": {
    "apiVersion": {"const": "botctl.dev/v0"},
    "kind": {"const": "ObservedGraph"},
    "generated_at": {"type": "string"},
    "source": {"type": "object"},
    "runtime_probe": {"type": "object"},
    "nodes": {"type": "array"},
    "edges": {"type": "array"},
    "findings": {"type": "array"}
  },
  "additionalProperties": true
}
